{
  "name": "@pixel63/game",
  "type": "module",
  "source": "src/library.ts",
  "main": "./build/library.js",
  "exports": {
    ".": {
      "import": "./build/library.js"
    }
  },
  "targets": {
    "game": {
      "context": "browser",
      "outputFormat": "esmodule",
      "isLibrary": false,
      "distDir": "../../build/game"
    },
    "library": {
      "context": "browser",
      "outputFormat": "esmodule",
      "isLibrary": true,
      "distDir": "build"
    }
  },
  "scripts": {
    "start": "npm run watch",
    "build": "npx parcel build src/index.tsx --dist-dir ../../build/game --target game --no-cache",
    "build:lib": "parcel build src/library.ts --dist-dir build --target library",
    "watch": "npx parcel watch src/index.tsx --dist-dir ../../build/game --target game --no-cache",
    "spritesheet": "npx ts-node src/UserInterface/utils/generateSpritesheet.ts",
    "spritesheet:loader": "npx ts-node src/loader/utils/generateSpritesheet.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@pixel63/events": "file:../events",
    "@pixel63/shared": "file:../shared",
    "@types/js-cookie": "^3.0.6",
    "js-cookie": "^3.0.5",
    "react": "^19.1.0",
    "react-color-palette": "^7.3.1",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@parcel/validator-eslint": "^2.16.4",
    "@parcel/validator-typescript": "^2.16.4",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/react": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@types/node-sprite-generator": "^0.10.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-storybook": "10.2.19",
    "node-sprite-generator": "^0.10.2",
    "parcel": "^2.16.4",
    "process": "^0.11.10",
    "storybook": "^10.2.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "alias": {
    "@Client/*": "./src/Client/$1",
    "@UserInterface/*": "./src/UserInterface/$1"
  }
}
